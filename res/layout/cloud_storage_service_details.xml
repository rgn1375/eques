<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:id="@id/realay_rootView" android:background="@color/cloud_storage_details_bg" android:fitsSystemWindows="true" android:layout_width="match_parent" android:layout_height="match_parent"
