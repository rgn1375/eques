<?xml version="1.0" encoding="utf-8"?>
<ScrollView android:background="@color/settings_view_bg" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:background="@color/settings_view_bg" android:paddingTop="@dimen/dp_20" android:layout_width="match_parent" android:layout_height="wrap_content">
        <ImageView android:layout_gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/ic_m1_setting" />
        <View android:background="@color/settings_view_bg" android:layout_width="match_parent" android:layout_height="@dimen/dp_20" />
        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical" android:id="@id/m1_set_parent" android:layout_width="match_parent" android:layout_height="wrap_content">
                <LinearLayout android:id="@id/linear_m1_network" android:background="@drawable/dev_details_page_btn_style" android:visibility="visible" style="@style/LinearLayoutParent">
                    <TextView android:text="@string/the_wireless_network_settings" style="@style/textView_btn_style" />
                    <TextView android:id="@id/tv_net_link_mode" style="@style/setting_right_tv_color_style" />
                    <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="@dimen/dp_15" android:src="@drawable/icon_arrow_selector" />
                </LinearLayout>
                <LinearLayout android:id="@id/linear_marsRing" android:background="@drawable/dev_details_page_btn_style" android:visibility="visible" style="@style/LinearLayoutParent">
                    <TextView android:text="@string/mars_ringtone" style="@style/textView_btn_style" />
                    <TextView android:id="@id/tv_mars_detailsRingtone" style="@style/setting_right_tv_color_style" />
                    <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="@dimen/dp_15" android:src="@drawable/icon_arrow_selector" />
                </LinearLayout>
                <LinearLayout android:id="@id/linear_marsVolume" android:background="@drawable/dev_details_page_btn_style" android:visibility="visible" android:layout_marginBottom="@dimen/dp_10" style="@style/LinearLayoutParent">
                    <TextView android:text="@string/mars_volume" style="@style/textView_btn_style" />
                    <TextView android:id="@id/tv_mars_detailsVolume" style="@style/setting_right_tv_color_style" />
                    <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="@dimen/dp_15" android:src="@drawable/icon_arrow_selector" />
                </LinearLayout>
                <LinearLayout android:id="@id/linear_marsUpdate" android:background="@drawable/dev_details_page_btn_style" android:visibility="visible" style="@style/LinearLayoutParent">
                    <TextView android:text="@string/mars_update" style="@style/textView_btn_style" />
                    <TextView android:id="@id/tv_mars_detailsUpdate" style="@style/setting_right_tv_color_style" />
                    <TextView android:textSize="@dimen/fontsize_fourteen" android:textColor="@color/white" android:gravity="right" android:id="@id/tv_m1_update_satus" android:background="@drawable/update_btn" android:paddingLeft="@dimen/dp_8" android:paddingRight="@dimen/dp_8" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="@dimen/dp_10" android:text="@string/device_need_update" />
                    <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="@dimen/dp_15" android:src="@drawable/icon_arrow_selector" />
                </LinearLayout>
                <LinearLayout android:orientation="horizontal" android:background="@color/settings_view_bg" android:paddingTop="@dimen/dp_9" android:paddingBottom="@dimen/dp_9" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:textColor="@color/loading_device_textcolor" android:ellipsize="end" android:paddingLeft="@dimen/fiveteen" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/mars_version" android:singleLine="true" />
                    <TextView android:textColor="@color/loading_device_textcolor" android:id="@id/tv_marsVersions" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>
                <LinearLayout android:id="@id/linear_marsRecover" android:background="@drawable/dev_details_page_btn_style" android:visibility="visible" style="@style/LinearLayoutParent">
                    <TextView android:text="@string/factory_data_reset_settings" style="@style/textView_btn_style" />
                    <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="@dimen/dp_15" android:src="@drawable/icon_arrow_selector" />
                </LinearLayout>
            </LinearLayout>
            <View android:id="@id/dev_notonline_bg" android:background="@drawable/camera_tab_bar_bg" android:visibility="gone" android:layout_width="match_parent" android:layout_height="wrap_content" android:alpha="0.7" />
        </RelativeLayout>
        <Button android:id="@id/btn_marsUnbundle" android:layout_marginTop="@dimen/dp_52" android:layout_alignParentBottom="true" style="@style/btn_style_setting_unbundle" />
        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/dp_10" android:layout_marginBottom="@dimen/dp_15">
            <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerInParent="true">
                <TextView android:textSize="@dimen/fontsize_fourteen" android:textColor="@color/settings_bottom_tv_color" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/dev_mac" />
                <TextView android:textSize="@dimen/fontsize_fourteen" android:textColor="@color/settings_bottom_tv_color" android:id="@id/tv_m1devId" android:layout_width="match_parent" android:layout_height="wrap_content" android:textIsSelectable="true" />
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
</ScrollView>
