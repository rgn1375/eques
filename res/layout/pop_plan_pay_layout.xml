            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout android:id="@id/rl_discount_coupon_parent" android:background="@color/white" android:visibility="gone" android:layout_width="match_parent" android:layout_height="@dimen/dp_50" android:paddingStart="@dimen/dp_15" android:paddingEnd="@dimen/dp_15">
            <TextView android:textSize="@dimen/fontsize_sixteen" android:textColor="@color/service_cloud_plan_one" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/service_buy_mode_payment_discount_coupon" android:layout_centerVertical="true" />
            <TextView android:textSize="@dimen/fontsize_sixteen" android:textColor="@color/service_open_details_color" android:textColorHint="@color/service_cloud_plan_three" android:gravity="right|center" android:id="@id/tv_discount_coupon_parent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:hint="@string/service_buy_mode_payment_discount_coupon_code" android:drawablePadding="@dimen/dp_5" android:layout_centerVertical="true" android:drawableEnd="@drawable/arrow_icon_default" android:layout_alignParentEnd="true" />
