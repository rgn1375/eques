            <View android:background="@color/login_e1e1e1" android:layout_width="@dimen/dp_70" android:layout_height="@dimen/dp_1" />
            <TextView android:textSize="@dimen/sp_14" android:textColor="@color/login_666666" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/login_third_des" android:layout_marginStart="@dimen/dp_10" android:layout_marginEnd="@dimen/dp_10" />
            <View android:background="@color/login_e1e1e1" android:layout_width="@dimen/dp_70" android:layout_height="@dimen/dp_1" />
        </LinearLayout>
        <include layout="@layout/lg_login_third_layout" />
