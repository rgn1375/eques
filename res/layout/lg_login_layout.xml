        <TextView android:textSize="@dimen/sp_16" android:textColor="@color/login_333333" android:gravity="center" android:id="@id/tv_sms_login" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/dp_14" android:layout_marginBottom="@dimen/dp_14" android:text="@string/sms_login" android:drawableRight="@mipmap/login_next" android:drawablePadding="@dimen/dp_3" />
        <TextView android:textSize="@dimen/sp_16" android:textColor="@color/login_333333" android:gravity="center" android:id="@id/tv_sms" android:visibility="gone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/dp_14" android:layout_marginBottom="@dimen/dp_14" android:text="@string/sms_login" />
        <include layout="@layout/lg_login_et_username" />
        <include layout="@layout/lg_login_et_pwd" />
