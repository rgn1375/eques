        <EditText android:textSize="@dimen/sp_16" android:textColor="@color/login_333333" android:textColorHint="@color/login_999999" android:id="@id/et_lg_code" android:background="@drawable/lg_et_style" android:paddingLeft="@dimen/dp_14" android:paddingRight="@dimen/dp_14" android:visibility="gone" android:layout_width="match_parent" android:layout_height="@dimen/dp_50" android:layout_marginTop="@dimen/dp_10" android:layout_marginBottom="@dimen/dp_20" android:hint="@string/input_success_authinfo" android:singleLine="true" android:inputType="number" android:imeOptions="actionDone" />
        <TextView android:textSize="@dimen/sp_15" android:textColor="@color/login_666666" android:layout_gravity="end" android:id="@id/tv_lg_forget_pwd" android:padding="@dimen/dp_8" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/login_forget_hint" />
