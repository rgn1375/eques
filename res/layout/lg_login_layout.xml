<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:id="@id/rl_login_parent" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <RelativeLayout android:id="@id/rel_start_login" android:background="@drawable/login_new_bg" android:layout_width="match_parent" android:layout_height="match_parent">
        <TextView android:textSize="@dimen/sp_40" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/dp_80" android:text="@string/login_new_app_name" android:layout_centerHorizontal="true" />
        <TextView android:textSize="@dimen/sp_20" android:textColor="@color/white" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/dp_140" android:text="@string/login_new_ui_ai" android:layout_centerHorizontal="true" />
        <TextView android:textSize="@dimen/sp_14" android:textColor="@color/white" android:gravity="center" android:id="@id/tv_server" android:background="@drawable/btn_half_coner_transport" android:paddingLeft="@dimen/dp_15" android:paddingTop="@dimen/dp_10" android:paddingRight="@dimen/dp_15" android:paddingBottom="@dimen/dp_10" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/dp_260" android:text="@string/get_service" android:drawableLeft="@mipmap/login_location" android:drawableRight="@mipmap/login_next" android:drawablePadding="@dimen/dp_15" android:layout_centerInParent="true" />
