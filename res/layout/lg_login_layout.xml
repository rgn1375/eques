    <LinearLayout android:orientation="vertical" android:id="@id/lin_login_username" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="@dimen/dp_20" android:layout_alignParentTop="true" android:layout_marginStart="@dimen/dp_20" android:layout_marginEnd="@dimen/dp_20">
        <ImageView android:id="@id/img_login_back" android:paddingRight="@dimen/dp_30" android:paddingBottom="@dimen/dp_14" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/dp_14" android:src="@drawable/lg_login_back_arrows" />
