<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:id="@id/rel_root" android:background="@color/white" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout android:id="@id/rel_nodata" android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:gravity="center" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/dp_50">
            <com.aigestudio.wheelpicker.WheelPicker android:id="@id/number_hour" android:background="#ffffff" android:layout_width="@dimen/dp_70" android:layout_height="match_parent" android:layout_marginStart="@dimen/dp_20" android:layout_marginEnd="@dimen/dp_20" app:wheel_item_text_color="@color/black" app:wheel_item_text_size="@dimen/sp_20" />
            <com.aigestudio.wheelpicker.WheelPicker android:id="@id/number_min" android:background="#ffffff" android:layout_width="@dimen/dp_70" android:layout_height="match_parent" android:layout_marginStart="@dimen/dp_20" android:layout_marginEnd="@dimen/dp_20" app:wheel_item_text_color="@color/black" app:wheel_item_text_size="@dimen/sp_20" />
        </LinearLayout>
        <Button android:textSize="@dimen/sp_20" android:textColor="@color/white" android:id="@id/btn_add" android:background="@drawable/btn_style_read_orange" android:layout_width="match_parent" android:layout_height="@dimen/dp_50" android:layout_marginTop="@dimen/dp_25" android:layout_marginBottom="@dimen/dp_25" android:text="@string/ok" android:layout_alignParentBottom="true" android:layout_marginStart="@dimen/dp_25" android:layout_marginEnd="@dimen/dp_25" />
    </RelativeLayout>
    <RelativeLayout android:id="@id/rel_data" android:visibility="gone" android:layout_width="match_parent" android:layout_height="match_parent">
        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/dp_100" android:layout_centerHorizontal="true">
            <com.eques.doorbell.ui.view.CircleProgressView android:id="@id/cp_progress_bar" android:layout_width="@dimen/dp_250" android:layout_height="@dimen/dp_250" android:layout_centerInParent="true" />
            <TextView android:textSize="50.0sp" android:textColor="@color/white" android:id="@id/tv_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00" android:layout_centerInParent="true" />
        </RelativeLayout>
        <Button android:textSize="@dimen/sp_20" android:textColor="@color/white" android:id="@id/btn_close" android:background="@drawable/btn_style_read_orange" android:layout_width="match_parent" android:layout_height="@dimen/dp_50" android:layout_marginTop="@dimen/dp_25" android:layout_marginBottom="@dimen/dp_25" android:text="@string/plug_clock_close" android:layout_alignParentBottom="true" android:layout_marginStart="@dimen/dp_25" android:layout_marginEnd="@dimen/dp_25" />
    </RelativeLayout>
</RelativeLayout>
