<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:background="@color/settings_view_bg" android:layout_width="match_parent" android:layout_height="match_parent"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:id="@id/ll_use_help" android:background="@drawable/dev_details_page_btn_style" android:visibility="visible" android:layout_marginTop="@dimen/dp_15" style="@style/LinearLayoutParent">
        <TextView android:id="@id/tv_help_name" android:text="@string/set_ele_instruction_menu" style="@style/textView_btn_style" />
        <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="@dimen/dp_15" android:src="@drawable/icon_arrow_selector" />
    </LinearLayout>
    <LinearLayout android:id="@id/ll_faq" android:background="@drawable/dev_details_page_btn_style" android:visibility="visible" android:layout_marginTop="@dimen/dp_8" style="@style/LinearLayoutParent">
        <TextView android:text="@string/set_faq_menu" style="@style/textView_btn_style" />
        <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="@dimen/dp_15" android:src="@drawable/icon_arrow_selector" />
    </LinearLayout>
    <LinearLayout android:id="@id/ll_call_center" android:background="@drawable/dev_details_page_btn_style" android:visibility="visible" android:layout_marginTop="@dimen/dp_8" style="@style/LinearLayoutParent">
        <TextView android:text="@string/customer_service_center_hint" style="@style/textView_btn_style" />
        <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="@dimen/dp_15" android:src="@drawable/icon_arrow_selector" />
    </LinearLayout>
    <LinearLayout android:id="@id/ll_open_debug" android:background="@drawable/dev_details_page_btn_style" android:visibility="visible" android:layout_marginTop="@dimen/dp_8" style="@style/LinearLayoutParent">
        <TextView android:text="@string/debug" style="@style/textView_btn_style" />
        <ImageView android:id="@id/img_debug_state" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginRight="@dimen/dp_15" android:src="@mipmap/button_switch_off" />
    </LinearLayout>
    <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <ImageView android:id="@id/img_er" android:layout_width="@dimen/dp_200" android:layout_height="@dimen/dp_200" android:layout_centerInParent="true" />
        <TextView android:textSize="@dimen/sp_16" android:textColor="@color/text_color" android:gravity="center" android:id="@id/tv_number" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/dp_14" android:layout_below="@id/img_er" android:layout_centerHorizontal="true" />
    </RelativeLayout>
</LinearLayout>
