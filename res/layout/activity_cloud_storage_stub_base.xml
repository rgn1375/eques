        </LinearLayout>
    </LinearLayout>
    <LinearLayout style="@style/cloudStorageServicePlanLinearLayoutStyle">
        <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/icon_cloudstorage_serviceplan_five" android:contentDescription="@null" />
