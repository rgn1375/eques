        <LinearLayout android:orientation="vertical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginLeft="@dimen/dp_16">
            <TextView android:text="长久保存" style="@style/cloudStorageServicePlanTextStyleOne" />
            <TextView android:text="被收藏的报警,长久保存在云端" style="@style/cloudStorageServicePlanTextStyleTwo" />
