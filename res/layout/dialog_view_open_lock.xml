<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:textSize="@dimen/sp_14" android:textColor="@color/white" android:gravity="center" android:id="@id/tv_open_lock_message" android:padding="@dimen/dp_20" android:layout_width="match_parent" android:layout_height="match_parent" android:text="@string/enter_the_unlock_password" />
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:paddingLeft="@dimen/dp_20" android:paddingRight="@dimen/dp_20" android:paddingBottom="@dimen/dp_20" android:layout_width="match_parent" android:layout_height="wrap_content">
        <EditText android:textColor="@color/edit_register_send" android:id="@id/et_input_lock_passwd" android:background="@drawable/image_input_box" android:padding="@dimen/dp_5" android:layout_width="match_parent" android:layout_height="@dimen/dp_40" android:singleLine="true" android:layout_weight="1.0" android:inputType="numberPassword" android:imeOptions="flagNoExtractUi" />
        <Button android:textSize="@dimen/sp_14" android:textColor="@color/black" android:id="@id/btn_submit_open_lock" android:background="@drawable/image_buttons_cancel" android:layout_width="wrap_content" android:layout_height="@dimen/dp_40" android:layout_marginLeft="@dimen/dp_10" android:text="@string/cancel" android:layout_weight="0.0" />
    </LinearLayout>
</LinearLayout>
