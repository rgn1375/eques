<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:left="1.0px" android:top="1.0px" android:right="1.0px" android:bottom="1.0px">
                <shape>
                    <solid android:color="@color/white" />
                    <corners android:radius="15.0dp" />
                    <stroke android:width="1.0dp" android:color="@color/viewfinder_border" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="false">
        <layer-list>
            <item android:left="1.0px" android:top="1.0px" android:right="1.0px" android:bottom="1.0px">
                <shape>
                    <solid android:color="@color/white" />
                    <corners android:radius="15.0dp" />
                    <stroke android:width="1.0dp" android:color="@color/interval_bg" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
