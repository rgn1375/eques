<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#ffebebeb" />
            <stroke android:width="2.0dp" android:color="#ffebebeb" />
            <corners android:radius="@dimen/dp_5" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape>
            <stroke android:width="0.0dp" />
            <solid android:color="#ffebebeb" />
            <corners android:radius="@dimen/dp_5" />
            <padding android:left="20.0dp" android:top="5.0dp" android:right="20.0dp" android:bottom="5.0dp" />
        </shape>
    </item>
    <item>
        <shape>
            <stroke android:width="0.0dp" />
            <solid android:color="#ffebebeb" />
            <corners android:radius="@dimen/dp_5" />
            <padding android:left="20.0dp" android:top="5.0dp" android:right="20.0dp" android:bottom="5.0dp" />
        </shape>
    </item>
</selector>
