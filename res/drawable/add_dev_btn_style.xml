<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="4.0dp">
                <shape>
                    <solid android:color="@color/gray" />
                    <corners android:radius="10.0dp" />
                    <stroke android:width="1.0dp" android:color="@color/gray" />
                </shape>
            </item>
            <item android:bottom="1.0dp">
                <shape>
                    <solid android:color="@color/add_dev_btn_shade_color" />
                    <corners android:radius="10.0dp" />
                    <stroke android:width="1.0dp" android:color="@color/add_dev_btn_shade_color" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="false">
        <layer-list>
            <item android:top="4.0dp">
                <shape>
                    <solid android:color="@color/add_dev_btn_shade_color" />
                    <corners android:radius="10.0dp" />
                    <stroke android:width="1.0dp" android:color="@color/add_dev_btn_shade_color" />
                </shape>
            </item>
            <item android:bottom="1.0dp">
                <shape>
                    <solid android:color="@color/white" />
                    <corners android:radius="10.0dp" />
                    <stroke android:width="1.0dp" android:color="@color/white" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
