<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="5.0dp" />
            <gradient android:startColor="#373737" android:endColor="#373737" android:angle="270.0" android:centerY="0.75" />
        </shape>
    </item>
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape>
                <corners android:radius="5.0dp" />
                <gradient android:startColor="#f0a901" android:endColor="#f0a901" android:angle="270.0" android:centerY="0.75" />
            </shape>
        </clip>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="5.0dp" />
                <gradient android:startColor="#f0a901" android:endColor="#f0a901" android:angle="0.0" android:centerY="0.75" />
            </shape>
        </clip>
    </item>
</layer-list>
